ConnectionStrings__DefaultConnection=
JwtSettings__SupabaseJwtSecret=
JwtSettings__SupabaseUrl=
EmailSettings__AppPassword=

# AI Provider Toggle ("OpenAI" or "Gemini")
AI_PROVIDER="OpenAI"

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"

# Gemini Configuration
GEMINI_PROVIDER=api-key
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash,gemini-2.5-flash,gemini-3.5-flash
GEMINI_MODEL=gemini-3.5-flash

# Optional: Vertex AI Configuration
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_ACCESS_TOKEN=
VERTEX_AI_SERVICE_ACCOUNT_PATH=
VERTEX_AI_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Google Workspace OAuth for Meet/Calendar link generation
# Requires OAuth scopes such as https://www.googleapis.com/auth/meetings.space.created
# or https://www.googleapis.com/auth/calendar.events. API keys cannot create private
# Google Meet spaces or Calendar events.
GOOGLE_WORKSPACE_ACCESS_TOKEN=

# Live Copilot Configuration (Gemini Native Audio/Text)
AGENT_PLATFORM_API_KEY=
LIVE_INTERVIEW_GEMINI_API_KEYS=
LIVE_INTERVIEW_GEMINI_MODELS=gemini-2.5-flash-native-audio-preview-12-2025,gemini-3-flash-preview,gemini-3.5-live-translate-preview
LIVE_INTERVIEW_GEMINI_TEXT_FALLBACK_MODEL=gemini-3.1-flash-lite
